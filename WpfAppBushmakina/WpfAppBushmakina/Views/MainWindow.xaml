<Window x:Class="Bushmakina.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bushmakina - Партнёры" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#E3F2FD">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить" Command="{Binding CreatePartnerCommand}" 
                        Background="#4CAF50" Foreground="White" 
                        Padding="15,8" Margin="0,0,10,0" FontSize="13"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="✏️ Изменить" Command="{Binding ModifyPartnerCommand}" 
                        Background="#FF9800" Foreground="White" 
                        Padding="15,8" Margin="0,0,10,0" FontSize="13"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="🗑️ Удалить" Command="{Binding DeletePartnerCommand}" 
                        Background="#F44336" Foreground="White" 
                        Padding="15,8" Margin="0,0,10,0" FontSize="13"
                        BorderThickness="0" Cursor="Hand"/>

                <Separator Width="20" Background="Transparent"/>

                <Button Content="💰 Добавить продажу" Command="{Binding AddSaleCommand}" 
                        Background="#9C27B0" Foreground="White" 
                        Padding="15,8" FontSize="13"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15,10" BorderBrush="#BDBDBD" BorderThickness="0,1,0,1">
            <Grid>
                <TextBlock Text="📋 Список партнёров" FontSize="16" FontWeight="Bold" Foreground="#1976D2"/>
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right" 
                           VerticalAlignment="Center" Foreground="#666" FontSize="13"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="5" 
                    BorderBrush="#1976D2" BorderThickness="2"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1976D2" Padding="10,8">
                        <TextBlock Text="ПАРТНЁРЫ" FontWeight="Bold" Foreground="White" FontSize="14"/>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Partners}" 
                             SelectedItem="{Binding SelectedPartner}"
                             SelectionMode="Single"
                             BorderThickness="0"
                             Background="#FAFAFA">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" 
                                        Margin="5" Padding="10" Background="White"
                                        CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="Bold" FontSize="14" Foreground="#1976D2">
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Type.TypeName, FallbackValue=''}" 
                                                       FontSize="11" Foreground="#757575" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding DirectorName}" 
                                                       FontSize="11" Foreground="#424242" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Phone}" 
                                                       FontSize="11" Foreground="#424242"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <Border Background="#FF9800" CornerRadius="10" Padding="5,2">
                                                    <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}'}" 
                                                               Foreground="White" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="#4CAF50" CornerRadius="15" 
                                                Padding="10,5" Margin="10,0,0,0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding CurrentBonus, StringFormat={}{0}%}" 
                                                       Foreground="White" FontWeight="Bold" FontSize="14"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="5" 
                    BorderBrush="#4CAF50" BorderThickness="2"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#4CAF50" Padding="10,8">
                        <TextBlock Text="📊 ИСТОРИЯ ПРОДАЖ" FontWeight="Bold" Foreground="White" FontSize="14"/>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F5E9" Padding="10">
                            <TextBlock FontWeight="Bold" Foreground="#2E7D32">
                                <Run Text="Партнёр: "/>
                                <Run Text="{Binding SelectedPartner.Name, FallbackValue='не выбран'}"/>
                                <Run Text=" | Бонус: "/>
                                <Run Text="{Binding CurrentBonus, StringFormat={}{0}%}"/>
                            </TextBlock>
                        </Border>

                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding SalesHistory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  Background="White"
                                  BorderThickness="0"
                                  RowHeight="35"
                                  AlternatingRowBackground="#F1F8E9">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#C8E6C9"/>
                                    <Setter Property="Foreground" Value="#1B5E20"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="📅 Дата" 
                                                    Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}" 
                                                    Width="120"/>
                                <DataGridTextColumn Header="📦 Продукция" 
                                                    Binding="{Binding ProductName}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="🔢 Количество" 
                                                    Binding="{Binding Quantity}" 
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>


    </Grid>
</Window>