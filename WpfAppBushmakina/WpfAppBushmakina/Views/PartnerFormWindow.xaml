<Window x:Class="Bushmakina.WPF.Views.PartnerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка партнёра" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#E3F2FD">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1976D2" Padding="15,10" CornerRadius="5,5,0,0">
            <TextBlock Text="📝 Информация о партнёре" FontWeight="Bold" FontSize="16" Foreground="White"/>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" 
                BorderBrush="#1976D2" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5">
            <ScrollViewer>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование *" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Partner.Name}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип партнёра *" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Types}" 
                              SelectedValuePath="Id" DisplayMemberPath="TypeName"
                              SelectedValue="{Binding SelectedTypeId}" 
                              Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ИНН" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Partner.INN}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Рейтинг *" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Partner.Rating}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Адрес" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Partner.Address}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="ФИО директора" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Partner.DirectorName}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Телефон" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Partner.Phone}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Email" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Partner.Email}" 
                             Height="30" Margin="10,5" FontSize="13"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Места продаж" 
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Partner.SalesPlaces}" 
                             Height="60" Margin="10,5" FontSize="13"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Width="120" Height="35" Margin="0,0,10,0" 
                    Click="BtnCancel_Click" FontSize="13"
                    Background="#9E9E9E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Сохранить" Width="120" Height="35" 
                    Click="BtnSave_Click" FontSize="13"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>