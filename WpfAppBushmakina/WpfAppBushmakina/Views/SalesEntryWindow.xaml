<Window x:Class="Bushmakina.WPF.Views.SalesEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая продажа" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#E8F5E9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#4CAF50" Padding="15,10" CornerRadius="5,5,0,0">
            <TextBlock Text="💰 Добавление продажи" FontWeight="Bold" FontSize="16" Foreground="White"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" Padding="20" 
                BorderBrush="#4CAF50" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="Наименование продукции *" 
                           FontWeight="Bold" Margin="0,0,0,5" Foreground="#2E7D32"/>
                <TextBox Text="{Binding ProductName}" Height="35" Margin="0,0,0,15" 
                         FontSize="14" BorderBrush="#81C784" BorderThickness="1"/>

                <TextBlock Text="Количество *" 
                           FontWeight="Bold" Margin="0,0,0,5" Foreground="#2E7D32"/>
                <TextBox Text="{Binding Quantity}" Height="35" Margin="0,0,0,15" 
                         FontSize="14" BorderBrush="#81C784" BorderThickness="1"/>

                <TextBlock Text="Дата продажи" 
                           FontWeight="Bold" Margin="0,0,0,5" Foreground="#2E7D32"/>
                <DatePicker SelectedDate="{Binding SaleDate}" Height="35" Margin="0,0,0,15" 
                            FontSize="14" BorderBrush="#81C784" BorderThickness="1"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Width="120" Height="35" Margin="0,0,10,0" 
                    Click="BtnCancel_Click" FontSize="13"
                    Background="#9E9E9E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Добавить" Width="120" Height="35" 
                    Click="BtnSave_Click" FontSize="13"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>